# Public RPC endpoint used for read-only contract calls before a wallet is connected.
# Local example: http://127.0.0.1:8545
# Sepolia example: https://sepolia.infura.io/v3/<key> or your Zama-compatible Sepolia RPC.
VITE_RPC_URL=http://127.0.0.1:8545

# Deployed contract addresses.
VITE_PRIVINVOICE_ADDRESS=
VITE_USDZ_ADDRESS=

# Address that the Company dashboard grants auditor ACL access to.
VITE_DEFAULT_AUDITOR_ADDRESS=

# First block to query PrivInvoice events from. Set this to the deployment block in production.
VITE_PRIVINVOICE_DEPLOY_BLOCK=0

# Set to true to run the full Company/Investor/Auditor UI workflow with local mock data
# instead of wallet/FHE/RPC calls.
VITE_ENABLE_MOCK_DATA=false
